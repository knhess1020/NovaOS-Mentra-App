PACKAGE_NAME=ai.valaria.forge
MENTRAOS_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME
PORT=3000
OPENAI_MODEL=gpt-5
WAKE_WORD=nova

# UX timing (ms)
THINKING_MS=1200
REPLY_MS=12000

# Streaming HUD update cadence (ms)
STREAM_UPDATE_MS=250

# Wake-arm TTL: how long "Armed…" state lasts after bare wake word (ms)
WAKE_ARM_MS=8000

# HUD word-wrap
MAX_LINES=7
MAX_CHARS_PER_LINE=28
